rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Legwan — Firestore Security Rules
//
// Architecture: each boutique has an isolated subtree at boutiques/{boutiqueId}.
// The boutiqueId is the Firebase Auth UID. A boutique starts anonymous, then can
// be linked to Email/Password so the same UID can be restored on a new machine.
//
// Rule: only the authenticated user whose UID matches the boutiqueId can
//       read or write their boutique's data. No other user can access it.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Boutique root document and all subcollections ────────────────────────
    match /boutiques/{boutiqueId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == boutiqueId;
    }

    match /boutiques/{boutiqueId}/{subcollection}/{docId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == boutiqueId;
    }

    // ── Nested sub-subcollections (e.g. settings/main) ───────────────────────
    match /boutiques/{boutiqueId}/{subcollection}/{docId}/{rest=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == boutiqueId;
    }

    // ── Platform registry (developer super-admin monitoring) ─────────────────
    // Each boutique writes its own heartbeat entry.
    // Only the developer (identified by email) can list and read all entries.
    // Platform registry — top-level collection (1 segment = valid collection path)
    // registry/{boutiqueId} : each boutique writes its own heartbeat entry
    match /registry/{boutiqueId} {
      // Boutique writes its own entry only, with data validation
      allow write: if request.auth != null
                   && request.auth.uid == boutiqueId
                   && request.resource.data.boutiqueId == boutiqueId
                   && request.resource.data.nom is string
                   && request.resource.data.nom.size() <= 200
                   && request.resource.data.adresse is string
                   && request.resource.data.adresse.size() <= 500
                   && request.resource.data.telephone is string
                   && request.resource.data.telephone.size() <= 50
                   && request.resource.data.version is string
                   && request.resource.data.version.size() <= 20;
      // Developer reads any entry — verified via Firebase custom claim, not email
      allow read: if request.auth != null
                  && request.auth.token.superadmin == true;
    }

    // Security events (login attempts) — boutique writes, no external read
    match /boutiques/{boutiqueId}/security/{document} {
      allow read, write: if request.auth != null
                         && request.auth.uid == boutiqueId;
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
