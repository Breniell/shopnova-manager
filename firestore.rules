rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Legwan — Firestore Security Rules
//
// Architecture: each boutique has an isolated subtree at boutiques/{boutiqueId}
// The boutiqueId = the Firebase Anonymous Auth UID of the device.
//
// Rule: only the authenticated user whose UID matches the boutiqueId can
//       read or write their boutique's data. No other user can access it.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Boutique root document and all subcollections ────────────────────────
    match /boutiques/{boutiqueId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == boutiqueId;
    }

    match /boutiques/{boutiqueId}/{subcollection}/{docId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == boutiqueId;
    }

    // ── Nested sub-subcollections (e.g. settings/main) ───────────────────────
    match /boutiques/{boutiqueId}/{subcollection}/{docId}/{rest=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == boutiqueId;
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
