{
  "name": "legwan-manager",
  "private": true,
  "version": "1.6.0",
  "description": "Logiciel de gestion commerciale pour boutiques (POS, stocks, rapports)",
  "author": "Legwan <support@legwan.cm>",
  "main": "electron/launcher.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:client": "cross-env VITE_ENABLE_SUPERADMIN=false vite build",
    "build:admin": "cross-env VITE_ENABLE_SUPERADMIN=true vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "security:prod": "npm audit --omit=dev --audit-level=high",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "playwright test tests/demo.spec.ts",
    "demo:merge": "node scripts/merge-demo-videos.js",
    "electron:dev": "concurrently \"vite --port 8080\" \"wait-on http://localhost:8080 && electron electron/launcher.cjs\"",
    "electron:build": "vite build --mode electron",
    "electron:build:client": "cross-env VITE_ENABLE_SUPERADMIN=false vite build --mode electron",
    "electron:build:admin": "cross-env VITE_ENABLE_SUPERADMIN=true vite build --mode electron",
    "electron:dist": "node scripts/build-electron.js",
    "electron:dist:x64": "node scripts/build-electron.js",
    "electron:dist:safe": "node scripts/build-electron.js",
    "dist:client": "node scripts/build-electron.js",
    "dist:internal": "npm run dist:client && node scripts/prepare-internal-package.mjs",
    "internal:prepare": "node scripts/prepare-internal-package.mjs",
    "dist:admin": "node scripts/build-electron.js --variant=admin",
    "release:preflight": "node scripts/release-preflight.mjs --release",
    "release:verify": "node scripts/verify-release.mjs --require-signature",
    "release:client": "node scripts/build-electron.js --release",
    "test:electron-runtime": "node --test tests/electron-runtime.test.mjs",
    "smoke:offline": "node scripts/smoke-electron.mjs",
    "smoke:offline:packaged": "node scripts/smoke-electron.mjs --packaged",
    "staff:claims": "node scripts/set-staff-claims.mjs",
    "firestore:deploy-rules": "node scripts/deploy-firestore-rules.mjs",
    "prepare-release": "npm run lint && npm run typecheck && npm run security:prod && npm test && npm run test:electron-runtime && npm run release:client",
    "release": "npm run prepare-release"
  },
  "dependencies": {
    "@fontsource-variable/nunito-sans": "^5.2.7",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-query": "^5.83.0",
    "@types/jsbarcode": "^3.11.4",
    "@zxing/browser": "^0.1.4",
    "@zxing/library": "^0.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "electron-updater": "^6.8.3",
    "embla-carousel-react": "^8.6.0",
    "firebase": "^12.11.0",
    "input-otp": "^1.4.2",
    "jsbarcode": "^3.12.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.462.0",
    "next-themes": "^0.3.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.61.1",
    "react-leaflet": "^4.2.1",
    "react-leaflet-cluster": "^2.1.0",
    "react-resizable-panels": "^2.1.9",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^0.9.9",
    "zod": "^3.25.76",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "firebase-admin": "^14.0.0",
    "globals": "^15.15.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.5"
  }
}
