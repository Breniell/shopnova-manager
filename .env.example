# ─────────────────────────────────────────────────────────────────────────────
# Legwan — Firebase Configuration
#
# 1. Allez sur https://console.firebase.google.com
# 2. Créez un projet Firebase (gratuit)
# 3. Activez Firestore Database (mode production)
# 4. Activez Authentication > Anonymous Sign-in
# 5. Dans Project Settings > General > Your apps > Web app
#    Copiez les valeurs ci-dessous
# 6. Copiez ce fichier en .env et remplissez les valeurs
# 7. Ne commitez JAMAIS le fichier .env sur GitHub
# ─────────────────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=votre-projet.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=votre-projet
VITE_FIREBASE_STORAGE_BUCKET=votre-projet.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
